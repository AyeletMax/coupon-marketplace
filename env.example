# העתיקי לקובץ .env (בשורש הפרויקט) והתאמי את הערכים.
# הקובץ .env לא עולה ל-Git – רק env.example משמש כדוגמה.

# MySQL – משמש את Docker ואת ה-Backend
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=coupon_marketplace
MYSQL_USER=app
MYSQL_PASSWORD=apppassword
# פורט MySQL במחשב (3307 כי 3306 לרוב תפוס)
MYSQL_PORT=3307

# Reseller API Token
RESELLER_TOKEN=secret-reseller-token

# פורט ה-Backend – אם 3000 תפוס, שימי כאן למשל 3001
PORT=3001
